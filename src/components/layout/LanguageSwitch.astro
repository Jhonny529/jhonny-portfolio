---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'en' } = Astro.props;

const nextHref = lang === 'en' ? '/es/' : '/';
const label = lang === 'en' ? 'ES' : 'EN';
const ariaLabel =
  lang === 'en' ? 'Cambiar a español' : 'Switch to English';
---

<a
  href={nextHref}
  class="lang-switch"
  aria-label={ariaLabel}
  transition:name="language-switch"
>
  <svg
    class="lang-globe"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10" />
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
    <path d="M2 12h20" />
  </svg>

  <span>{label}</span>
</a>

<style>
  .lang-switch {
    display: inline-flex;
    min-width: 92px;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 9999px;
    border: 1px solid rgb(212 212 212 / 0.6);
    background: rgb(255 255 255 / 0.7);
    padding: 0.62rem 0.95rem;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    color: rgb(64 64 64);
    text-decoration: none;
    transition:
      background-color 200ms ease,
      color 200ms ease,
      border-color 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }

  :global(.dark) .lang-switch {
    border-color: rgb(255 255 255 / 0.1);
    background: rgb(255 255 255 / 0.04);
    color: rgb(229 229 229);
  }

  .lang-switch:hover {
    transform: translateY(-2px);
    background: rgb(255 255 255);
    color: rgb(23 23 23);
    border-color: rgb(34 197 94 / 0.35);
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.08);
  }

  :global(.dark) .lang-switch:hover {
    background: rgb(255 255 255 / 0.07);
    color: white;
    border-color: rgb(34 197 94 / 0.4);
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.28);
  }

  .lang-globe {
    flex-shrink: 0;
    transition: transform 400ms ease;
  }

  .lang-switch:hover .lang-globe {
    transform: rotate(22deg);
  }
</style>