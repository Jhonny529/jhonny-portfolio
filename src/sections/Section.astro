---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from './home/Hero.astro';
import About from './home/About.astro';
import Projects from './home/Projects.astro';
import Experience from './home/Experience.astro';
import Contact from './home/Contact.astro';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'en' } = Astro.props;
---

<Header lang={lang} />

<main class="mx-auto max-w-6xl px-6" transition:name="page-content">
  <section id="home">
    <Hero lang={lang} />
  </section>

  <section id="about" class="border-t border-neutral-200 py-20 dark:border-white/10 md:py-24">
    <About lang={lang} />
  </section>

    <!--
  <section id="projects" class="border-t border-neutral-200 py-20 dark:border-white/10 md:py-24">
    <Projects lang={lang} />
  </section>
  -->
  
  <section id="experience" class="border-t border-neutral-200 py-20 dark:border-white/10 md:py-24">
    <Experience lang={lang} />
  </section>

  <section id="contact" class="border-t border-neutral-200 py-20 dark:border-white/10 md:py-24">
    <Contact lang={lang} />
  </section>
</main>

<Footer lang={lang} />

